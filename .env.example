# Shared local development example. Copy to .env and replace secrets locally.

# Backend
ROOM_MONITOR_DB=backend/data/room_monitor.sqlite3
ROOM_MONITOR_WRITE_API_KEY=change-this-write-secret
ROOM_MONITOR_READ_API_KEY=change-this-read-secret
ROOM_MONITOR_MAX_BODY_BYTES=4096
ROOM_MONITOR_RATE_LIMIT_REQUESTS=30
ROOM_MONITOR_RATE_LIMIT_WINDOW_SECONDS=60
ROOM_MONITOR_RETENTION_DAYS=30
ROOM_MONITOR_BACKUP_DIR=backend/backups
ROOM_MONITOR_BACKUP_RETENTION_DAYS=14

# Raspberry Pi collector
SERIAL_PORT=/dev/ttyACM0
SERIAL_BAUD=115200
LOCAL_DB=raspberry_pi/data/room_readings.sqlite3
LOCAL_RETENTION_DAYS=30
LOCAL_PRUNE_EVERY_SECONDS=3600
UPLOAD_URL=https://YOUR_BACKEND_HOST/api/readings
UPLOAD_EVERY_SECONDS=60
