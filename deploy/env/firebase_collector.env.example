SERIAL_PORT=/dev/ttyACM0
SERIAL_BAUD=115200
LOCAL_DB=/opt/stm32_raspberrypi_practice/raspberry_pi/data/room_readings.sqlite3
LOCAL_RETENTION_DAYS=30
LOCAL_PRUNE_EVERY_SECONDS=3600
FIREBASE_DATABASE_URL=https://YOUR_PROJECT_ID-default-rtdb.firebaseio.com
FIREBASE_API_KEY=your-firebase-web-api-key
FIREBASE_DEVICE_EMAIL=room-device@example.com
FIREBASE_DEVICE_PASSWORD=change-this-device-password
FIREBASE_UPLOAD_EVERY_SECONDS=60
FIREBASE_RETENTION_DAYS=30
FIREBASE_PRUNE_EVERY_SECONDS=86400
FIREBASE_PRUNE_BATCH_SIZE=200
