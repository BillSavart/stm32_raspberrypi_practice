[Unit]
Description=Room Monitor FastAPI backend
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=roommonitor
Group=roommonitor
WorkingDirectory=/opt/stm32_raspberrypi_practice/backend
EnvironmentFile=/etc/room-monitor/backend.env
ExecStart=/opt/stm32_raspberrypi_practice/backend/.venv/bin/uvicorn app:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
